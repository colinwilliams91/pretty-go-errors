{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "lib": ["ES2020"],
    "paths": {
      "@pretty-go-errors/utils": ["packages/utils/src"],
      "@pretty-go-errors/formatter": ["packages/formatter/src"],
      "@pretty-go-errors/vscode-formatter": ["packages/vscode-formatter/src"]
    }
  }
}
